#!/bin/sh

if ! command -v npm >/dev/null 2>&1; then
  export PATH="/opt/homebrew/bin:/usr/local/bin:$PATH"
fi

should_build=0

while read -r local_ref local_oid remote_ref remote_oid
do
  if [ "$local_ref" = "refs/heads/main" ] || [ "$remote_ref" = "refs/heads/main" ]; then
    should_build=1
    break
  fi
done

if [ "$should_build" -ne 1 ]; then
  echo "Skipping pre-push build: push does not target main."
  exit 0
fi

echo "Running pre-push build for main..."
npm run build
